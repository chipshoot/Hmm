@page
@model Hmm.Idp.Pages.Account.ConfirmEmailModel
@{
    ViewData["Title"] = "Confirm Email";
}

<div class="confirm-email-page">
    <h1>Email Verification</h1>

    @if (Model.Success)
    {
        <div class="alert alert-success">
            <strong>Verified.</strong> @Model.Message
        </div>
        @if (Model.IsFromMobile)
        {
            <p>You can now close this tab and sign in from the Hmm Console app on your device.</p>
        }
        else
        {
            <p>
                <a class="btn btn-primary" href="@Model.SignInUrl">Sign in</a>
            </p>
        }
    }
    else
    {
        <div class="alert alert-danger">
            @Model.Message
        </div>
        <p>
            <a class="btn btn-secondary" asp-page="/Account/ResendConfirmation">Resend verification email</a>
        </p>
    }
</div>
