@page
@model Hmm.Idp.Pages.Home.Index

<div class="welcome-page">
    <h1>
        <img src="~/hmm-logo.svg" class="logo" onerror="this.src='~/duende-logo.svg'; this.onerror=null;">
        Welcome to HomeMadeMessage Identity Service
        <small class="text-muted">(version @Model.Version)</small>
    </h1>

    <p class="lead">
        HomeMadeMessage Identity Service provides secure authentication and identity management for all HomeMadeMessage
        applications.
    </p>

    <div class="card-deck">
        <div class="card shadow-sm">
            <div class="card-body">
                <h5 class="card-title">For Users</h5>
                <p class="card-text">
                    Here you can manage your account, view your profile, and check applications you've authorized.
                </p>
                <ul>
                    <li>
                        <a href="~/diagnostics">View your current session information</a>
                    </li>
                    <li>
                        <a href="~/grants">Manage your application permissions</a>
                    </li>
                </ul>
            </div>
        </div>

        <div class="card shadow-sm">
            <div class="card-body">
                <h5 class="card-title">Technical Information</h5>
                <p class="card-text">
                    Resources for developers and administrators.
                </p>
                <ul>
                    <li>
                        <a href="~/.well-known/openid-configuration">OpenID Connect discovery document</a>
                    </li>
                    <li>
                        <a href="~/serversidesessions">Server side sessions</a>
                    </li>
                    <li>
                        <a href="~/ApiResources">API Resources</a>
                    </li>
                </ul>
            </div>
        </div>
    </div>
</div>
