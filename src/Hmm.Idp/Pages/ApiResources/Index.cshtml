@page
@model Hmm.Idp.Pages.ApiResources.IndexModel
@{
    ViewData["Title"] = "API Resources";
}

<h2>API Resources</h2>

<p>
    <a asp-page="Create" class="btn btn-primary">Create New API Resource</a>
</p>

<table class="table table-striped">
    <thead>
    <tr>
        <th>Name</th>
        <th>Display Name</th>
        <th>Description</th>
        <th>Enabled</th>
        <th>Actions</th>
    </tr>
    </thead>
    <tbody>
    @foreach (var apiResource in Model.ApiResources)
    {
        <tr>
            <td>@apiResource.Name</td>
            <td>@apiResource.DisplayName</td>
            <td>@apiResource.Description</td>
            <td>@(apiResource.Enabled ? "Yes" : "No")</td>
            <td>
                <a asp-page="Edit" asp-route-name="@apiResource.Name" class="btn btn-sm btn-primary">Edit</a>
                <a asp-page="Details" asp-route-name="@apiResource.Name" class="btn btn-sm btn-info">Details</a>
                <a asp-page="Delete" asp-route-name="@apiResource.Name" class="btn btn-sm btn-danger">Delete</a>
            </td>
        </tr>
    }
    </tbody>
</table>