@page
@model Hmm.Idp.Pages.Admin.Roles.IndexModel
@{
    ViewData["Title"] = "Roles";
}

<h1>Roles</h1>

<p>
    <a asp-page="Create" class="btn btn-primary">Create New Role</a>
</p>

<table class="table">
    <thead>
        <tr>
            <th>Name</th>
            <th>Description</th>
            <th>Users</th>
            <th>Actions</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var role in Model.Roles)
        {
            <tr>
                <td>@role.Name</td>
                <td>@role.Description</td>
                <td>@role.UserCount</td>
                <td>
                    <a asp-page="./Edit" asp-route-id="@role.Id" class="btn btn-sm btn-secondary">Edit</a>
                    <a asp-page="./Details" asp-route-id="@role.Id" class="btn btn-sm btn-info">Details</a>
                    @if (!string.Equals(role.Name, "Administrator", StringComparison.OrdinalIgnoreCase))
                    {
                        <a asp-page="./Delete" asp-route-id="@role.Id" class="btn btn-sm btn-danger">Delete</a>
                    }
                </td>
            </tr>
        }
    </tbody>
</table>
