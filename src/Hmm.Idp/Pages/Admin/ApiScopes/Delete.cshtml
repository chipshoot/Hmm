@page "{id:int}"
@model Hmm.Idp.Pages.Admin.ApiScopes.DeleteModel
@{
    ViewData["Title"] = "Delete API Scope";
}

<h1>Delete API Scope</h1>

<div class="alert alert-warning">Are you sure you want to delete this scope?</div>

<div>
    <h4>@Model.Scope.Name</h4>
    <hr />
    <dl class="row">
        <dt class="col-sm-3">Name</dt>
        <dd class="col-sm-9">@Model.Scope.Name</dd>

        <dt class="col-sm-3">Display Name</dt>
        <dd class="col-sm-9">@Model.Scope.DisplayName</dd>

        <dt class="col-sm-3">Enabled</dt>
        <dd class="col-sm-9">@(Model.Scope.Enabled ? "Yes" : "No")</dd>
    </dl>

    <form method="post">
        <input type="hidden" asp-for="Scope.Id" />
        <input type="submit" value="Delete" class="btn btn-danger" />
        <a asp-page="./Index" class="btn btn-secondary">Cancel</a>
    </form>
</div>
