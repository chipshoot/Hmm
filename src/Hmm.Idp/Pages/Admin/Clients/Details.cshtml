@page "{id:int}"
@model Hmm.Idp.Pages.Admin.Clients.DetailsModel
@{
    ViewData["Title"] = "Client Details";
}

<h1>Client Details</h1>

<div>
    <h4>@Model.Client.ClientName</h4>
    <hr />
    <dl class="row">
        <dt class="col-sm-3">Client ID</dt>
        <dd class="col-sm-9">@Model.Client.ClientId</dd>

        <dt class="col-sm-3">Client Name</dt>
        <dd class="col-sm-9">@Model.Client.ClientName</dd>

        <dt class="col-sm-3">Description</dt>
        <dd class="col-sm-9">@Model.Client.Description</dd>

        <dt class="col-sm-3">Enabled</dt>
        <dd class="col-sm-9">@(Model.Client.Enabled ? "Yes" : "No")</dd>

        <dt class="col-sm-3">Require PKCE</dt>
        <dd class="col-sm-9">@(Model.Client.RequirePkce ? "Yes" : "No")</dd>

        <dt class="col-sm-3">Allow Offline Access</dt>
        <dd class="col-sm-9">@(Model.Client.AllowOfflineAccess ? "Yes" : "No")</dd>

        <dt class="col-sm-3">Update Claims On Refresh</dt>
        <dd class="col-sm-9">@(Model.Client.UpdateAccessTokenClaimsOnRefresh ? "Yes" : "No")</dd>

        <dt class="col-sm-3">Access Token Lifetime</dt>
        <dd class="col-sm-9">@Model.Client.AccessTokenLifetime seconds</dd>

        <dt class="col-sm-3">Identity Token Lifetime</dt>
        <dd class="col-sm-9">@Model.Client.IdentityTokenLifetime seconds</dd>

        <dt class="col-sm-3">Absolute Refresh Lifetime</dt>
        <dd class="col-sm-9">@Model.Client.AbsoluteRefreshTokenLifetime seconds</dd>

        <dt class="col-sm-3">Sliding Refresh Lifetime</dt>
        <dd class="col-sm-9">@Model.Client.SlidingRefreshTokenLifetime seconds</dd>

        <dt class="col-sm-3">Grant Types</dt>
        <dd class="col-sm-9">
            @if (Model.Client.AllowedGrantTypes?.Any() == true)
            {
                <ul>
                    @foreach (var grant in Model.Client.AllowedGrantTypes)
                    {
                        <li>@grant.GrantType</li>
                    }
                </ul>
            }
            else { <em>(none)</em> }
        </dd>

        <dt class="col-sm-3">Redirect URIs</dt>
        <dd class="col-sm-9">
            @if (Model.Client.RedirectUris?.Any() == true)
            {
                <ul>
                    @foreach (var uri in Model.Client.RedirectUris)
                    {
                        <li>@uri.RedirectUri</li>
                    }
                </ul>
            }
            else { <em>(none)</em> }
        </dd>

        <dt class="col-sm-3">Post-Logout Redirect URIs</dt>
        <dd class="col-sm-9">
            @if (Model.Client.PostLogoutRedirectUris?.Any() == true)
            {
                <ul>
                    @foreach (var uri in Model.Client.PostLogoutRedirectUris)
                    {
                        <li>@uri.PostLogoutRedirectUri</li>
                    }
                </ul>
            }
            else { <em>(none)</em> }
        </dd>

        <dt class="col-sm-3">Allowed Scopes</dt>
        <dd class="col-sm-9">
            @if (Model.Client.AllowedScopes?.Any() == true)
            {
                <ul>
                    @foreach (var scope in Model.Client.AllowedScopes)
                    {
                        <li>@scope.Scope</li>
                    }
                </ul>
            }
            else { <em>(none)</em> }
        </dd>

        <dt class="col-sm-3">Allowed CORS Origins</dt>
        <dd class="col-sm-9">
            @if (Model.Client.AllowedCorsOrigins?.Any() == true)
            {
                <ul>
                    @foreach (var origin in Model.Client.AllowedCorsOrigins)
                    {
                        <li>@origin.Origin</li>
                    }
                </ul>
            }
            else { <em>(none)</em> }
        </dd>

        <dt class="col-sm-3">Client Claims</dt>
        <dd class="col-sm-9">
            @if (Model.Client.Claims?.Any() == true)
            {
                <ul>
                    @foreach (var claim in Model.Client.Claims)
                    {
                        <li>@claim.Type = @claim.Value</li>
                    }
                </ul>
            }
            else { <em>(none)</em> }
        </dd>

        <dt class="col-sm-3">Secrets</dt>
        <dd class="col-sm-9">
            @if (Model.Client.ClientSecrets?.Any() == true)
            {
                <ul>
                    @foreach (var secret in Model.Client.ClientSecrets)
                    {
                        <li>@secret.Type (created @secret.Created.ToString("u"))</li>
                    }
                </ul>
            }
            else { <em>(none)</em> }
        </dd>
    </dl>
</div>

<div>
    <a asp-page="./Edit" asp-route-id="@Model.Client.Id" class="btn btn-primary">Edit</a>
    <a asp-page="./Index" class="btn btn-secondary">Back to List</a>
</div>
