@page
@model Hmm.Idp.Pages.Admin.User.IndexModel
@{
    ViewData["Title"] = "User Management";
}

<div class="user-management-page">
    <h1>User Management</h1>
    <p>Manage users of the Hmm Identity system.</p>

    <div class="row mb-3">
        <div class="col-auto">
            <a asp-page="./Create" class="btn btn-primary">Create New User</a>
        </div>
        <div class="col">
            <form method="get" class="d-flex">
                <input type="text" name="Query" value="@Model.Query" class="form-control me-2" placeholder="Search by username or email" />
                <button type="submit" class="btn btn-secondary">Search</button>
                @if (!string.IsNullOrEmpty(Model.Query))
                {
                    <a asp-page="./Index" class="btn btn-link">Clear</a>
                }
            </form>
        </div>
    </div>

    <div class="card">
        <div class="card-header">
            <h2>Users (@Model.TotalUsers total)</h2>
        </div>
        <div class="card-body">
            @if (!Model.Users.Any())
            {
                <p>No users found.</p>
            }
            else
            {
                <table class="table table-bordered table-striped">
                    <thead>
                        <tr>
                            <th>Username</th>
                            <th>Email</th>
                            <th>Roles</th>
                            <th>Active</th>
                            <th>Locked</th>
                            <th>Last Login</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var user in Model.Users)
                        {
                            <tr>
                                <td>@user.UserName</td>
                                <td>@user.Email</td>
                                <td>@user.Roles</td>
                                <td>@(user.IsActive ? "Yes" : "No")</td>
                                <td>@(user.IsLockedOut ? "Yes" : "No")</td>
                                <td>@(user.LastLoginAt?.ToString("u") ?? "-")</td>
                                <td>
                                    <a asp-page="./Details" asp-route-id="@user.Id" class="btn btn-info btn-sm">Details</a>
                                    <a asp-page="./Edit" asp-route-id="@user.Id" class="btn btn-warning btn-sm">Edit</a>
                                    <a asp-page="./Delete" asp-route-id="@user.Id" class="btn btn-danger btn-sm">Delete</a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>

                @if (Model.TotalPages > 1)
                {
                    <nav>
                        <ul class="pagination">
                            @for (var p = 1; p <= Model.TotalPages; p++)
                            {
                                <li class="page-item @(p == Model.Page ? "active" : "")">
                                    <a class="page-link" asp-page="./Index" asp-route-Page="@p" asp-route-Query="@Model.Query">@p</a>
                                </li>
                            }
                        </ul>
                    </nav>
                }
            }
        </div>
    </div>
</div>
