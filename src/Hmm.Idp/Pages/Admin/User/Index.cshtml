@page
@model Hmm.Idp.Pages.Admin.User.IndexModel
@{
    ViewData["Title"] = "User Management";
}

<div class="user-management-page">
    <h1>User Management</h1>
    <p>Manage users of hmmIdp system</p>

    <div class="row mb-3">
        <div class="col">
            <a asp-page="./Create" class="btn btn-primary">Create New User</a>
        </div>
    </div>

    <div class="card">
        <div class="card-header">
            <h2>Users</h2>
        </div>
        <div class="card-body">
            @if (!Model.Users.Any())
            {
                <p>No users found.</p>
            }
            else
            {
                <table class="table table-bordered table-striped">
                    <thead>
                        <tr>
                            <th>Username</th>
                            <th>Subject ID</th>
                            <th>Claims</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var user in Model.Users)
                        {
                            <tr>
                                <td>@user.UserName</td>
                                <td>@user.SubjectId</td>
                                <td>
                                    @if (user.GetClaims().Any())
                                    {
                                        <ul>
                                            @foreach (var claim in user.GetClaims().Take(2))
                                            {
                                                <li>@claim.Type: @claim.Value</li>
                                            }
                                            @if (user.GetClaims().Count() > 2)
                                            {
                                                <li>...</li>
                                            }
                                        </ul>
                                    }
                                </td>
                                <td>
                                    <a asp-page="./Details" asp-route-id="@user.SubjectId"
                                        class="btn btn-info btn-sm">Details</a>
                                    <a asp-page="./Edit" asp-route-id="@user.SubjectId" class="btn btn-warning btn-sm">Edit</a>
                                    <a asp-page="./Delete" asp-route-id="@user.SubjectId"
                                        class="btn btn-danger btn-sm">Delete</a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            }
        </div>
    </div>
</div>