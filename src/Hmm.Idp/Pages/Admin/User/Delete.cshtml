@page "{id}"
@model Hmm.Idp.Pages.Admin.User.DeleteModel
@{
    ViewData["Title"] = "Delete User";
}

<h1>Delete User</h1>

<div class="alert alert-warning">Are you sure you want to delete this user? This action cannot be undone.</div>

<dl class="row">
    <dt class="col-sm-3">Username</dt>
    <dd class="col-sm-9">@Model.User.UserName</dd>

    <dt class="col-sm-3">Email</dt>
    <dd class="col-sm-9">@Model.User.Email</dd>

    <dt class="col-sm-3">Full Name</dt>
    <dd class="col-sm-9">@Model.User.FirstName @Model.User.LastName</dd>
</dl>

<form method="post">
    <input type="submit" value="Delete" class="btn btn-danger" />
    <a asp-page="./Index" class="btn btn-secondary">Cancel</a>
</form>
