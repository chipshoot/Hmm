@page "{id}"
@model Hmm.Idp.Pages.Admin.User.EditModel
@{
    ViewData["Title"] = "Edit User";
}

<div class="edit-user-page">
    <h1>Edit User</h1>
    <p>Update user information, roles, and status.</p>

    @if (!string.IsNullOrEmpty(Model.StatusMessage))
    {
        <div class="alert alert-success">@Model.StatusMessage</div>
    }

    <div class="row">
        <div class="col-md-8">
            <div class="card">
                <div class="card-header">
                    <h2>User Details</h2>
                </div>
                <div class="card-body">
                    <form method="post">
                        <div asp-validation-summary="ModelOnly" class="text-danger"></div>
                        <input type="hidden" asp-for="Input.SubjectId" />

                        <div class="form-group mb-3">
                            <label asp-for="Input.Username"></label>
                            <input asp-for="Input.Username" class="form-control" />
                            <span asp-validation-for="Input.Username" class="text-danger"></span>
                        </div>

                        <div class="form-group mb-3">
                            <label asp-for="Input.FullName"></label>
                            <input asp-for="Input.FullName" class="form-control" />
                            <span asp-validation-for="Input.FullName" class="text-danger"></span>
                        </div>

                        <div class="form-group mb-3">
                            <label asp-for="Input.Email"></label>
                            <input asp-for="Input.Email" class="form-control" />
                            <span asp-validation-for="Input.Email" class="text-danger"></span>
                        </div>

                        <div class="form-group mb-3 form-check">
                            <input asp-for="Input.IsActive" class="form-check-input" />
                            <label asp-for="Input.IsActive" class="form-check-label"></label>
                        </div>

                        <div class="form-group mb-3">
                            <label asp-for="Input.Password"></label>
                            <input asp-for="Input.Password" class="form-control" autocomplete="new-password" />
                            <span asp-validation-for="Input.Password" class="text-danger"></span>
                            <small class="form-text text-muted">Leave blank to keep the current password. Use the Reset Password page to force-set.</small>
                        </div>

                        <div class="form-group mb-3">
                            <label asp-for="Input.ConfirmPassword"></label>
                            <input asp-for="Input.ConfirmPassword" class="form-control" autocomplete="new-password" />
                            <span asp-validation-for="Input.ConfirmPassword" class="text-danger"></span>
                        </div>

                        <h4 class="mt-4">Roles</h4>
                        <div class="form-group mb-3">
                            @if (Model.AllRoles.Any())
                            {
                                foreach (var role in Model.AllRoles)
                                {
                                    <div class="form-check">
                                        <input class="form-check-input" type="checkbox" name="Input.SelectedRoles" value="@role.Name" id="role_@role.Name" @(role.Selected ? "checked" : "") />
                                        <label class="form-check-label" for="role_@role.Name">@role.Name</label>
                                    </div>
                                }
                            }
                            else
                            {
                                <em>No roles defined. <a asp-page="/Admin/Roles/Create">Create one</a>.</em>
                            }
                        </div>

                        <div class="form-group mb-3">
                            <button type="submit" class="btn btn-primary">Save Changes</button>
                            <a asp-page="./Details" asp-route-id="@Model.Input.SubjectId" class="btn btn-info">View Details</a>
                            <a asp-page="./Index" class="btn btn-secondary">Cancel</a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
