{
  "AppSettings": {
    "DatabaseProvider": "SQLite",
    "IdpBaseUrl": "https://idp.homemademessage.com",
    "ApiAudience": "hmmapi",
    "CorsOrigins": [
      "https://idp.homemademessage.com",
      "https://homemademessage.com",
      "https://www.homemademessage.com"
    ]
  },
  "AttachmentSettings": {
    "// production default": "must live inside the systemd unit's ReadWritePaths= (/var/log/hmm-api /var/lib/hmm-api-data). The dev default ./hmm-vault-dev resolves under /opt/hmm-api which ProtectSystem=strict makes read-only — every vault write would 500.",
    "RootDir": "/var/lib/hmm-api-data/vault"
  },
  "ConnectionStrings": {
    "DefaultConnection": "Data Source=../hmm-data/hmm.db"
  },
  "Serilog": {
    "Using": [
      "Serilog.Sinks.Console",
      "Serilog.Sinks.File"
    ],
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "System": "Warning"
      }
    },
    "Enrich": [ "FromLogContext" ],
    "Properties": {
      "Service": "hmm-api"
    },
    "WriteTo": [
      {
        "Name": "Console",
        "Args": {
          "formatter": "Serilog.Formatting.Compact.CompactJsonFormatter, Serilog.Formatting.Compact"
        }
      },
      {
        "Name": "File",
        "Args": {
          "path": "/var/log/hmm-api/app-.json",
          "rollingInterval": "Day",
          "retainedFileCountLimit": 14,
          "formatter": "Serilog.Formatting.Compact.CompactJsonFormatter, Serilog.Formatting.Compact"
        }
      }
    ]
  }
}
