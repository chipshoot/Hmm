PATCH {{baseUrl}}/api/v{{apiVersion}}/automobiles/gasstations/1
Authorization: Bearer {{token}}
Content-Type: application/json-patch+json

[
  {
    "op": "replace",
    "path": "/description",
    "value": "Patched description"
  }
]

### Delete (deactivate) a gas station
DELETE {{baseUrl}}/api/v{{apiVersion}}/automobiles/gasstations/1
Authorization: Bearer {{token}}

