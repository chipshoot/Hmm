### Hmm.ServiceApi - HTTP Request Collection
### This file contains test requests for functional testing of the Hmm.ServiceApi

### ============================================================
### VARIABLES
### ============================================================

# Choose your environment by uncommenting ONE of the following:

# ---- Environment 1: IIS Express + Docker SQL Server ----
# Start infrastructure: .\scripts\Start-FuncTestInfra.ps1
# Run with: Visual Studio "IIS Express SqlServer" profile
# @baseUrl = https://localhost:44349
# @idpUrl = https://localhost:5001

# ---- Environment 2: Kestrel + Docker SQL Server ----
# Start infrastructure: .\scripts\Start-FuncTestInfra.ps1
# Run with: dotnet run --launch-profile "Hmm.ServiceApi SqlServer"
# @baseUrl = https://localhost:5002
# @idpUrl = https://localhost:5001

# ---- Environment 3: Full Docker Stack (Scenario 2) ----
# Start all: cd docker && ./hmm-setup.sh --scenario 2
# API: http://localhost:5010, IDP: http://localhost:5001, Seq: http://localhost:8081
@baseUrl = http://localhost:5010
@idpUrl = http://localhost:5001

# ---- Legacy: PostgreSQL Development ----
# Start with: docker-compose up (root docker-compose.yml)
# @baseUrl = https://localhost:5002
# @idpUrl = https://localhost:5001

@apiVersion = 1.0

# ============================================================
# AUTHENTICATION - GET TOKEN
# Run this request first to get a token, then use it below
# ============================================================

### Get Access Token (Resource Owner Password Grant)
# @name getToken
POST {{idpUrl}}/connect/token
Content-Type: application/x-www-form-urlencoded

grant_type=password&client_id=hmm.functest&client_secret=FuncTestSecret123!&username=testuser@hmm.local&password=TestPassword123!&scope=openid profile email hmmapi

### Get Access Token (Client Credentials - Machine to Machine)
# @name getM2MToken
POST {{idpUrl}}/connect/token
Content-Type: application/x-www-form-urlencoded

grant_type=client_credentials&client_id=hmm.m2m&client_secret=M2MSecret456!&scope=hmmapi

# ============================================================
# AUTHENTICATION TOKENS
# The API supports multiple identity providers. Use the appropriate token below.
# ============================================================

# Dynamic token from getToken request above (VS Code REST Client / Rider)
 @hmmIdpToken = {{getToken.response.body.access_token}}

# Or paste your token here manually:
#@hmmIdpToken = "eyJhbGciOiJSUzI1NiIsImtpZCI6IkNFRjJBRjY0OEU0RUREOTQ0NURDOUY2MTc0MzREQTRFIiwidHlwIjoiYXQrand0In0..MGW43nqvHGe0cUhx9QVXxqWlNBsFFXsgNhSGXGBcqAHobRPaNJVxwHToIe0BpoqlVSGDY2shLIF_6m5E9Tit3aJk_CrMqjlkqJkZHzz2kxrqEEf6-3edghSNEbzNRmuZMSWhmDe_j6jZuPT_QM2W5rjrMix1u00p4ZbNjZ4arkJFPP2tGi6SZ4HpMyqRsAI2YOpdgheWVF01WUWlagRswiLuB4hhSKKQicWBjqUtzZp2u27pENvb0ax2MGlGMo7qZj4b3ofls8BkxuCjtO3ODfKo8Ra32w0srLQJv00qg8yv-baonef9T9b8opZqGOFmY_GBruZpk4kBd1Gr5rh1pg"

# Firebase token - Get from Firebase Auth SDK or REST API
# POST https://identitytoolkit.googleapis.com/v1/accounts:signInWithPassword?key=YOUR_API_KEY
# Body: { "email": "user@example.com", "password": "password", "returnSecureToken": true }
@firebaseToken = YOUR_FIREBASE_TOKEN_HERE

# Auth0 token - Get from Auth0 Authentication API
# POST https://YOUR_DOMAIN.auth0.com/oauth/token
# Body: { "grant_type": "password", "client_id": "...", "username": "...", "password": "...", "audience": "..." }
@auth0Token = YOUR_AUTH0_TOKEN_HERE

# Azure AD token - Get from Microsoft Identity Platform
# POST https://login.microsoftonline.com/{tenant}/oauth2/v2.0/token
@azureAdToken = YOUR_AZURE_AD_TOKEN_HERE

# Active token - Change this to switch between providers for testing
@token = {{hmmIdpToken}}

### ============================================================
### HEALTH CHECK
### ============================================================

### Check if API is running (Swagger)
GET {{baseUrl}}/swagger/index.html

### ============================================================
### AUTHORS
### ============================================================

### Get all authors
GET {{baseUrl}}/api/v{{apiVersion}}/authors
Authorization: Bearer {{token}}

### Get all authors with pagination
GET {{baseUrl}}/api/v{{apiVersion}}/authors?PageNumber=1&PageSize=10
Authorization: Bearer {{token}}

### Get author by ID
GET {{baseUrl}}/api/v{{apiVersion}}/authors/1
Authorization: Bearer {{token}}

### Create a new author
POST {{baseUrl}}/api/v{{apiVersion}}/authors
Authorization: Bearer {{token}}
Content-Type: application/json

{
  "accountName": "testuser",
  "role": "Author",
  "isActivated": true,
  "description": "Test user for API testing",
  "contact": {
    "firstName": "Test",
    "lastName": "User",
    "emails": [
      {
        "address": "test@example.com",
        "isPrimary": true
      }
    ],
    "phones": [
      {
        "number": "555-123-4567",
        "isPrimary": true
      }
    ]
  }
}

### Update an author (PUT)
PUT {{baseUrl}}/api/v{{apiVersion}}/authors/1
Authorization: Bearer {{token}}
Content-Type: application/json

{
  "accountName": "updateduser",
  "role": "Author",
  "isActivated": true,
  "description": "Updated test user"
}

### Patch an author (PATCH)
PATCH {{baseUrl}}/api/v{{apiVersion}}/authors/1
Authorization: Bearer {{token}}
Content-Type: application/json-patch+json

[
  {
    "op": "replace",
    "path": "/description",
    "value": "Patched description"
  }
]

### Delete (deactivate) an author
DELETE {{baseUrl}}/api/v{{apiVersion}}/authors/1
Authorization: Bearer {{token}}

### ============================================================
### TAGS
### ============================================================

### Get all tags
GET {{baseUrl}}/api/v{{apiVersion}}/tags
Authorization: Bearer {{token}}

### Get all tags with pagination
GET {{baseUrl}}/api/v{{apiVersion}}/tags?PageNumber=1&PageSize=10
Authorization: Bearer {{token}}

### Get tag by ID
GET {{baseUrl}}/api/v{{apiVersion}}/tags/1
Authorization: Bearer {{token}}

### Get tag by name
GET {{baseUrl}}/api/v{{apiVersion}}/tags/work
Authorization: Bearer {{token}}

### Create a new tag
POST {{baseUrl}}/api/v{{apiVersion}}/tags
Authorization: Bearer {{token}}
Content-Type: application/json

{
  "name": "work",
  "description": "Work-related notes"
}

### Create another tag
POST {{baseUrl}}/api/v{{apiVersion}}/tags
Authorization: Bearer {{token}}
Content-Type: application/json

{
  "name": "personal",
  "description": "Personal notes"
}

### Create tag for automobile
POST {{baseUrl}}/api/v{{apiVersion}}/tags
Authorization: Bearer {{token}}
Content-Type: application/json

{
  "name": "vehicle",
  "description": "Vehicle maintenance and gas logs"
}

### Update a tag (PUT)
PUT {{baseUrl}}/api/v{{apiVersion}}/tags/1
Authorization: Bearer {{token}}
Content-Type: application/json

{
  "name": "updated-tag",
  "description": "Updated tag description"
}

### Patch a tag (PATCH)
PATCH {{baseUrl}}/api/v{{apiVersion}}/tags/1
Authorization: Bearer {{token}}
Content-Type: application/json-patch+json

[
  {
    "op": "replace",
    "path": "/description",
    "value": "Patched tag description"
  }
]

### Delete (deactivate) a tag
DELETE {{baseUrl}}/api/v{{apiVersion}}/tags/1
Authorization: Bearer {{token}}

### ============================================================
### NOTE CATALOGS
### ============================================================

### Get all note catalogs
GET {{baseUrl}}/api/v{{apiVersion}}/notecatalogs
Authorization: Bearer {{token}}

### Get all note catalogs with pagination
GET {{baseUrl}}/api/v{{apiVersion}}/notecatalogs?PageNumber=1&PageSize=10
Authorization: Bearer {{token}}

### Get note catalog by ID
GET {{baseUrl}}/api/v{{apiVersion}}/notecatalogs/1
Authorization: Bearer {{token}}

### Create a default plain text note catalog
POST {{baseUrl}}/api/v{{apiVersion}}/notecatalogs
Authorization: Bearer {{token}}
Content-Type: application/json

{
  "name": "Default",
  "formatType": 0,
  "schema": "",
  "isDefault": true,
  "description": "Default plain text note catalog"
}

### Create a JSON note catalog
POST {{baseUrl}}/api/v{{apiVersion}}/notecatalogs
Authorization: Bearer {{token}}
Content-Type: application/json

{
  "name": "JsonNotes",
  "formatType": 2,
  "schema": "{\"type\": \"object\", \"properties\": {\"title\": {\"type\": \"string\"}, \"body\": {\"type\": \"string\"}}}",
  "isDefault": false,
  "description": "JSON formatted note catalog"
}

### Create a Markdown note catalog
POST {{baseUrl}}/api/v{{apiVersion}}/notecatalogs
Authorization: Bearer {{token}}
Content-Type: application/json

{
  "name": "MarkdownNotes",
  "formatType": 3,
  "schema": "",
  "isDefault": false,
  "description": "Markdown formatted note catalog"
}

### Update a note catalog (PUT)
PUT {{baseUrl}}/api/v{{apiVersion}}/notecatalogs/1
Authorization: Bearer {{token}}
Content-Type: application/json

{
  "name": "UpdatedCatalog",
  "formatType": 0,
  "schema": "",
  "isDefault": true,
  "description": "Updated note catalog"
}

### Patch a note catalog (PATCH)
PATCH {{baseUrl}}/api/v{{apiVersion}}/notecatalogs/1
Authorization: Bearer {{token}}
Content-Type: application/json-patch+json

[
  {
    "op": "replace",
    "path": "/description",
    "value": "Patched note catalog description"
  }
]

### ============================================================
### NOTES
### ============================================================

### Get all notes
GET {{baseUrl}}/api/v{{apiVersion}}/notes
Authorization: Bearer {{token}}

### Get all notes with pagination
GET {{baseUrl}}/api/v{{apiVersion}}/notes?PageNumber=1&PageSize=10
Authorization: Bearer {{token}}

### Get all notes with sorting
GET {{baseUrl}}/api/v{{apiVersion}}/notes?PageNumber=1&PageSize=10&OrderBy=CreateDate desc
Authorization: Bearer {{token}}

### Get note by ID
GET {{baseUrl}}/api/v{{apiVersion}}/notes/1
Authorization: Bearer {{token}}

### Create a new note
# Note: Ensure AuthorId and CatalogId exist before running this
POST {{baseUrl}}/api/v{{apiVersion}}/notes
Authorization: Bearer {{token}}
Content-Type: application/json

{
  "subject": "My First Note",
  "content": "This is the content of my first test note.",
  "authorId": 1,
  "catalogId": 1,
  "description": "A test note for API testing"
}

### Create another note
POST {{baseUrl}}/api/v{{apiVersion}}/notes
Authorization: Bearer {{token}}
Content-Type: application/json

{
  "subject": "Meeting Notes",
  "content": "## Meeting Summary\n\n- Discussed project timeline\n- Assigned tasks\n- Next meeting scheduled for Friday",
  "authorId": 1,
  "catalogId": 1,
  "description": "Weekly team meeting notes"
}

### Create a JSON formatted note
POST {{baseUrl}}/api/v{{apiVersion}}/notes
Authorization: Bearer {{token}}
Content-Type: application/json

{
  "subject": "API Test Data",
  "content": "{\"testKey\": \"testValue\", \"items\": [1, 2, 3]}",
  "authorId": 1,
  "catalogId": 2,
  "description": "JSON formatted test data"
}

### Update a note (PUT)
PUT {{baseUrl}}/api/v{{apiVersion}}/notes/1
Authorization: Bearer {{token}}
Content-Type: application/json

{
  "subject": "Updated Note Subject",
  "content": "Updated note content goes here.",
  "description": "Updated description"
}

### Patch a note (PATCH)
PATCH {{baseUrl}}/api/v{{apiVersion}}/notes/1
Authorization: Bearer {{token}}
Content-Type: application/json-patch+json

[
  {
    "op": "replace",
    "path": "/subject",
    "value": "Patched Note Subject"
  },
  {
    "op": "replace",
    "path": "/content",
    "value": "Patched note content"
  }
]

### Apply a tag to a note
PUT {{baseUrl}}/api/v{{apiVersion}}/notes/1/applyTag
Authorization: Bearer {{token}}
Content-Type: application/json

{
  "name": "work"
}

### Apply another tag to a note
PUT {{baseUrl}}/api/v{{apiVersion}}/notes/1/applyTag
Authorization: Bearer {{token}}
Content-Type: application/json

{
  "name": "personal"
}

### Delete (soft delete) a note
DELETE {{baseUrl}}/api/v{{apiVersion}}/notes/1
Authorization: Bearer {{token}}

