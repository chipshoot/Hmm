### MULTI-PROVIDER AUTHENTICATION TESTS
### Use these to verify different identity providers work correctly
### ============================================================

### Test with Hmm.Idp token
GET {{baseUrl}}/api/v{{apiVersion}}/notes
Authorization: Bearer {{hmmIdpToken}}

### Test with Firebase token
GET {{baseUrl}}/api/v{{apiVersion}}/notes
Authorization: Bearer {{firebaseToken}}

### Test with Auth0 token
GET {{baseUrl}}/api/v{{apiVersion}}/notes
Authorization: Bearer {{auth0Token}}

### Test with Azure AD token
GET {{baseUrl}}/api/v{{apiVersion}}/notes
Authorization: Bearer {{azureAdToken}}

### ============================================================
### FIREBASE AUTHENTICATION EXAMPLES
### ============================================================

### Firebase: Sign in with email/password (get token)
# @name firebaseSignIn
# Replace YOUR_FIREBASE_API_KEY with your Firebase Web API Key
# POST https://identitytoolkit.googleapis.com/v1/accounts:signInWithPassword?key=YOUR_FIREBASE_API_KEY
# Content-Type: application/json
#
# {
#   "email": "test@example.com",
#   "password": "your-password",
#   "returnSecureToken": true
# }

### Firebase: Sign up new user
# @name firebaseSignUp
# POST https://identitytoolkit.googleapis.com/v1/accounts:signUp?key=YOUR_FIREBASE_API_KEY
# Content-Type: application/json
#
# {
#   "email": "newuser@example.com",
#   "password": "secure-password-123",
#   "returnSecureToken": true
# }

### Firebase: Refresh token
# POST https://securetoken.googleapis.com/v1/token?key=YOUR_FIREBASE_API_KEY
# Content-Type: application/x-www-form-urlencoded
#
# grant_type=refresh_token&refresh_token=YOUR_REFRESH_TOKEN

### ============================================================
### AUTH0 AUTHENTICATION EXAMPLES
### ============================================================

### Auth0: Get token with Resource Owner Password Grant
# @name auth0Token
# POST https://YOUR_DOMAIN.auth0.com/oauth/token
# Content-Type: application/json
#
# {
#   "grant_type": "password",
#   "client_id": "YOUR_CLIENT_ID",
#   "client_secret": "YOUR_CLIENT_SECRET",
#   "username": "user@example.com",
#   "password": "password",
#   "audience": "YOUR_API_IDENTIFIER",
#   "scope": "openid profile email"
# }

### Auth0: Get token with Client Credentials (machine-to-machine)
# POST https://YOUR_DOMAIN.auth0.com/oauth/token
# Content-Type: application/json
#
# {
#   "grant_type": "client_credentials",
#   "client_id": "YOUR_CLIENT_ID",
#   "client_secret": "YOUR_CLIENT_SECRET",
#   "audience": "YOUR_API_IDENTIFIER"
# }

### ============================================================
### AZURE AD AUTHENTICATION EXAMPLES
### ============================================================

### Azure AD: Get token with Resource Owner Password Grant
# @name azureAdToken
# POST https://login.microsoftonline.com/YOUR_TENANT_ID/oauth2/v2.0/token
# Content-Type: application/x-www-form-urlencoded
#
# grant_type=password
# &client_id=YOUR_CLIENT_ID
# &client_secret=YOUR_CLIENT_SECRET
# &username=user@yourdomain.com
# &password=your-password
# &scope=api://YOUR_CLIENT_ID/.default

### Azure AD: Get token with Client Credentials
# POST https://login.microsoftonline.com/YOUR_TENANT_ID/oauth2/v2.0/token
# Content-Type: application/x-www-form-urlencoded
#
# grant_type=client_credentials
# &client_id=YOUR_CLIENT_ID
# &client_secret=YOUR_CLIENT_SECRET
# &scope=api://YOUR_CLIENT_ID/.default
