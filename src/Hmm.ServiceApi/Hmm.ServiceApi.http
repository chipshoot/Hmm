### ============================================================
### GAS DISCOUNTS
### Route: /api/v{version}/automobiles/gaslogs/discounts
### ============================================================

### Get all gas discounts
GET {{baseUrl}}/api/v{{apiVersion}}/automobiles/gaslogs/discounts
Authorization: Bearer {{token}}

### Get gas discount by ID
GET {{baseUrl}}/api/v{{apiVersion}}/automobiles/gaslogs/discounts/1
Authorization: Bearer {{token}}

### Create a loyalty card discount
POST {{baseUrl}}/api/v{{apiVersion}}/automobiles/gaslogs/discounts
Authorization: Bearer {{token}}
Content-Type: application/json

{
  "program": "Petro Points",
  "discountType": "CentsPerLiter",
  "amount": 0.03,
  "currency": "CAD",
  "isActive": true,
  "comment": "Petro Canada loyalty program - 3 cents per liter"
}

### Create a credit card discount
POST {{baseUrl}}/api/v{{apiVersion}}/automobiles/gaslogs/discounts
Authorization: Bearer {{token}}
Content-Type: application/json

{
  "program": "Costco Mastercard",
  "discountType": "Percentage",
  "amount": 2.0,
  "currency": "CAD",
  "isActive": true,
  "comment": "2% cashback on gas purchases"
}

### Create a membership discount
POST {{baseUrl}}/api/v{{apiVersion}}/automobiles/gaslogs/discounts
Authorization: Bearer {{token}}
Content-Type: application/json

{
  "program": "CAA Member Discount",
  "discountType": "CentsPerLiter",
  "amount": 0.05,
  "currency": "CAD",
  "isActive": true,
  "comment": "CAA membership gas discount"
}

### Update a gas discount (PUT)
PUT {{baseUrl}}/api/v{{apiVersion}}/automobiles/gaslogs/discounts/1
Authorization: Bearer {{token}}
Content-Type: application/json

{
  "program": "Petro Points Plus",
  "discountType": "CentsPerLiter",
  "amount": 0.05,
  "currency": "CAD",
  "isActive": true,
  "comment": "Updated discount amount"
}

### Patch a gas discount (PATCH)
PATCH {{baseUrl}}/api/v{{apiVersion}}/automobiles/gaslogs/discounts/1
Authorization: Bearer {{token}}
Content-Type: application/json-patch+json

[
  {
    "op": "replace",
    "path": "/isActive",
    "value": false
  }
]

### Delete (deactivate) a gas discount
DELETE {{baseUrl}}/api/v{{apiVersion}}/automobiles/gaslogs/discounts/1
Authorization: Bearer {{token}}

### ============================================================
### GAS STATIONS
### Route: /api/v{version}/automobiles/gasstations
### ============================================================

### Get all gas stations
GET {{baseUrl}}/api/v{{apiVersion}}/automobiles/gasstations
Authorization: Bearer {{token}}

### Get active gas stations only
GET {{baseUrl}}/api/v{{apiVersion}}/automobiles/gasstations/active
Authorization: Bearer {{token}}

### Get gas station by ID
GET {{baseUrl}}/api/v{{apiVersion}}/automobiles/gasstations/1
Authorization: Bearer {{token}}

### Get gas station by name
GET {{baseUrl}}/api/v{{apiVersion}}/automobiles/gasstations/byname/Shell
Authorization: Bearer {{token}}

### Create a gas station (Shell)
POST {{baseUrl}}/api/v{{apiVersion}}/automobiles/gasstations
Authorization: Bearer {{token}}
Content-Type: application/json

{
  "name": "Shell - Main Street",
  "address": "123 Main Street",
  "city": "Toronto",
  "state": "ON",
  "zipCode": "M5V 1A1",
  "description": "24 hour gas station with convenience store",
  "isActive": true
}

