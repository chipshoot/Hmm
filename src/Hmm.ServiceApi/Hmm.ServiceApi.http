### ============================================================
### GAS LOGS
### ============================================================

### Get all gas logs for an automobile
GET {{baseUrl}}/api/v{{apiVersion}}/automobiles/1/gaslogs
Authorization: Bearer {{token}}

### Get gas logs with pagination and sorting
GET {{baseUrl}}/api/v{{apiVersion}}/automobiles/1/gaslogs?PageNumber=1&PageSize=10&OrderBy=Date desc
Authorization: Bearer {{token}}

### Get gas log by ID
GET {{baseUrl}}/api/v{{apiVersion}}/automobiles/1/gaslogs/1
Authorization: Bearer {{token}}

### Create a new gas log
POST {{baseUrl}}/api/v{{apiVersion}}/automobiles/1/gaslogs
Authorization: Bearer {{token}}
Content-Type: application/json

{
  "date": "2024-01-15T10:30:00",
  "automobileId": 1,
  "odometer": 15500,
  "odometerUnit": "Mile",
  "distance": 350,
  "distanceUnit": "Mile",
  "fuel": 10.5,
  "fuelUnit": "Gallon",
  "fuelGrade": "Regular",
  "isFullTank": true,
  "isFirstFillUp": false,
  "totalPrice": 35.50,
  "unitPrice": 3.38,
  "currency": "CAD",
  "stationId": null,
  "location": "Shell Station - Main Street",
  "cityDrivingPercentage": 60,
  "highwayDrivingPercentage": 40,
  "receiptNumber": "R-20240115-001",
  "comment": "Regular fill-up"
}

