{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "ServiceRecord Note",
  "type": "object",
  "required": ["note"],
  "definitions": {
    "money": {
      "type": "object",
      "required": ["value", "currencyCode"],
      "properties": {
        "value": { "type": "number", "minimum": 0 },
        "currencyCode": { "type": "string" }
      }
    },
    "partItem": {
      "type": "object",
      "required": ["name", "quantity"],
      "properties": {
        "name": { "type": "string", "minLength": 1, "maxLength": 100 },
        "quantity": { "type": "integer", "minimum": 1 },
        "unitCost": { "$ref": "#/definitions/money" }
      },
      "additionalProperties": false
    }
  },
  "properties": {
    "note": {
      "type": "object",
      "required": ["content"],
      "properties": {
        "content": {
          "type": "object",
          "required": ["ServiceRecord"],
          "properties": {
            "ServiceRecord": {
              "type": "object",
              "required": ["automobileId", "date", "mileage", "type"],
              "properties": {
                "automobileId": { "type": "integer", "minimum": 1 },
                "date": { "type": "string", "format": "date-time" },
                "mileage": { "type": "integer", "minimum": 0 },
                "type": {
                  "type": "string",
                  "enum": ["OilChange", "TireRotation", "Brake", "Inspection", "Repair", "Other"]
                },
                "description": { "type": "string", "maxLength": 1000 },
                "cost": { "$ref": "#/definitions/money" },
                "shopName": { "type": "string", "maxLength": 100 },
                "parts": {
                  "type": "array",
                  "items": { "$ref": "#/definitions/partItem" }
                },
                "notes": { "type": "string", "maxLength": 1000 },
                "createdDate": { "type": "string", "format": "date-time" }
              },
              "additionalProperties": false
            }
          }
        }
      }
    }
  }
}
