# Centralized environment configuration for Docker Compose
# Used by compose.base.yml, compose.idp.yml, and compose.api.yml

# SQL Server (kept for compose.base.yml's optional api-sqlserver container; the
# API itself no longer uses it — see compose.api.yml for the embedded-PG setup.)
API_SA_PASSWORD=Shcdlhgm1!
API_SQLSERVER_PORT=1433

# Seq Logging
SEQ_INGESTION_PORT=5341
SEQ_UI_PORT=8081

# Mailpit (dev SMTP catcher) — UI port. SMTP is fixed at 1025 inside the
# hmm-network; only the UI port is exposed to the host.
MAILPIT_UI_PORT=8025

# IDP
IDP_PORT=5001

# IDP PostgreSQL (embedded in hmm-idp container)
IDP_POSTGRES_PASSWORD=IdpDockerPassword1!

# API (using 5010 instead of 5000 to avoid macOS AirPlay Receiver conflict)
API_HTTP_PORT=5010

# API PostgreSQL (embedded in hmm-api container)
API_POSTGRES_PASSWORD=ApiDockerPassword1!

# Host ports for the embedded Postgres instances when compose.pgport.yml is
# attached (DBeaver / pgAdmin / psql access from the host). Override these if
# you have a local Postgres already listening on 5432/5433.
IDP_PG_HOST_PORT=5432
API_PG_HOST_PORT=5433
